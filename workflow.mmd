---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	User(User)
	Validate(Validate)
	Vision(Vision)
	Reasoning(Reasoning)
	Explain(Explain)
	Report(Report)
	Safety(Safety)
	__end__([<p>__end__</p>]):::last
	Explain --> Report;
	Reasoning --> Explain;
	Report --> Safety;
	User --> Validate;
	Validate --> Vision;
	Vision --> Reasoning;
	__start__ --> User;
	Safety --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
